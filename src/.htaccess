# ============================================
# KALA Genset ERP - Cache Busting Configuration
# ============================================

# Enable Rewrite Engine
RewriteEngine On

# ✅ Angular Routing Support
# Redirect all requests to index.html (for Angular routes to work)
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -f [OR]
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -d
RewriteRule ^ - [L]
RewriteRule ^ /ERPAngularUINew26/index.html [L]

# ✅ NEVER Cache index.html
# Browser will always fetch fresh index.html from server
<Files "index.html">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires 0
</Files>

# ✅ Cache Hashed JS and CSS Files for 1 Year
# Safe because Angular adds unique hash to filenames on every build
# e.g. main-es2015.aedfff8937b470adca7c.js
<FilesMatch "\.(js|css)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# ✅ Cache Images and Font Files for 1 Month
<FilesMatch "\.(png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
  Header set Cache-Control "public, max-age=2592000"
</FilesMatch>
